{
  "manifest_version": 3,
  "name": "TimeTrace",
  "version": "0.1",
  "description": "Track website usage time and view stored usage data in a popup.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TimeTrace"
  }
}
